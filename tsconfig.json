{
  "compilerOptions": {
    "outDir": "./dist",
    "target": "esnext",
    "module": "es2022",
    "moduleResolution": "bundler",
    "types": ["node"],
    "esModuleInterop": true,
    "strict": true,
    "allowJs": true,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "files": [
    "./eslint.config.ts",
    "./tsdown.config.ts",
    "./vitest.config.ts",
    "maplerad.config.js"
  ],
  "include": ["./src/**/*", "./tests/**/*"],
  "exclude": ["./dist", "./node_modules"]
}
